# Application
NODE_ENV=development
PORT=3000

# Database (matches docker-compose.yml). The shadow DB lives on the same
# TimescaleDB-capable server and is required by `prisma migrate dev`.
# These are consumed by Prisma once it is wired up (next PR).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/app?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/shadow?schema=public"

# Shared secret for the destructive Timescale admin mutations. If unset, the
# admin API is open in development and denied in production. When set, send it as
# the `x-admin-token` header.
# ADMIN_TOKEN=change-me
