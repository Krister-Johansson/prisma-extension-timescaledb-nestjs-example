# GraphQL endpoint the web app queries.
# Default (unset): same-origin "/graphql", proxied to the API by the Vite dev
# server (vite.config.ts). Set this to call the API directly (requires CORS):
# VITE_API_URL=http://localhost:3000/graphql

# Override the dev proxy target if the API isn't on localhost:3000:
# VITE_API_PROXY=http://localhost:3000
