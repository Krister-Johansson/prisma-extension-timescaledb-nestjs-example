{
  "name": "@timescale-demo/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "description": "Frontend demo for the prisma-extension-timescaledb dashboard (TanStack Router + Vite SPA)",
  "scripts": {
    "dev": "vite dev --port 3001",
    "predev": "npm run codegen",
    "build": "vite build",
    "prebuild": "npm run codegen",
    "preview": "vite preview --port 3001",
    "routes:generate": "tsr generate",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "screenshot": "node scripts/screenshot.mjs",
    "pretypecheck": "tsr generate && npm run codegen",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "es-toolkit": "^1.47.1",
    "graphql": "^16.14.2",
    "graphql-ws": "^6.0.8",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "victory-vendor": "^37.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/near-operation-file-preset": "^5.2.1",
    "@graphql-codegen/typed-document-node": "^7.0.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.4",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/router-cli": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.0"
  }
}
