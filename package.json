{
  "name": "prisma-extension-timescaledb-nestjs-example",
  "version": "0.0.1",
  "description": "Monorepo demo for prisma-extension-timescaledb (NestJS API + frontend)",
  "author": "Krister Johansson",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f timescaledb",
    "api:dev": "npm run start:dev --workspace @timescale-demo/api",
    "api:build": "npm run build --workspace @timescale-demo/api",
    "db:deploy": "npm run db:deploy --workspace @timescale-demo/api",
    "db:migrate": "npm run db:migrate --workspace @timescale-demo/api",
    "db:reset": "npm run db:reset --workspace @timescale-demo/api",
    "db:seed": "npm run db:seed --workspace @timescale-demo/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace @timescale-demo/api"
  }
}
